---

<section id="funcionalidades" class="py-24 sm:py-32 relative">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Section header -->
    <div class="fade-in text-center max-w-2xl mx-auto mb-16">
      <p class="text-sm font-medium text-brand-400 mb-3 tracking-wide uppercase">Funcionalidades</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Cálculo, no intuición
      </h2>
      <p class="text-surface-200/50 text-lg">
        Cada herramienta resuelve un problema concreto: cómo repartir tu portfolio, cuándo desplegar capital, cuándo esperar y cómo proteger tu cuenta.
      </p>
    </div>

    <!-- Feature grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {features.map((feature) => (
        <div class="fade-in group relative rounded-2xl border border-surface-800/50 bg-surface-900/30 p-6 hover:border-brand-700/30 hover:bg-surface-900/60 transition-all duration-300">
          <div class="w-10 h-10 rounded-xl bg-brand-600/10 border border-brand-700/20 flex items-center justify-center text-brand-400 mb-4 group-hover:bg-brand-600/20 transition-colors">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-base font-semibold text-white mb-2">{feature.title}</h3>
          <p class="text-sm text-surface-200/50 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
