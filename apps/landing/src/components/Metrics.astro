---

---

<section class="py-20 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-surface-950 via-brand-950/20 to-surface-950"></div>

  <div class="relative z-10 mx-auto max-w-6xl px-6">
    <div class="fade-in rounded-2xl border border-brand-700/15 bg-surface-900/40 backdrop-blur-sm p-8 sm:p-12">
      <div class="text-center mb-10">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">
          Los números detrás de la estrategia
        </h2>
        <p class="text-sm text-surface-200/40">
          Gestión activa con DCA condicional vs. buy-and-hold pasivo — simulación sobre datos reales 2015-2020
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Sharpe -->
        <div class="text-center">
          <div class="text-xs text-surface-200/30 uppercase tracking-wider mb-2">Ratio Sharpe</div>
          <div class="flex items-center justify-center gap-3 whitespace-nowrap">
            <div>
              <div class="text-xl sm:text-2xl font-bold text-accent-green">1.44‑2.13</div>
              <div class="text-[10px] text-surface-200/30 mt-0.5">Con gestión activa</div>
            </div>
            <div class="text-surface-200/20 text-xs">vs</div>
            <div>
              <div class="text-xl sm:text-2xl font-bold text-surface-200/30">0.81‑1.19</div>
              <div class="text-[10px] text-surface-200/30 mt-0.5">Pasivo</div>
            </div>
          </div>
          <div class="text-[10px] text-surface-200/25 mt-2">Rendimiento por unidad de riesgo</div>
        </div>

        <!-- Extra capital -->
        <div class="text-center">
          <div class="text-xs text-surface-200/30 uppercase tracking-wider mb-2">Capital extra generado</div>
          <div class="text-2xl font-bold text-white">$73K‑$213K</div>
          <div class="text-[10px] text-surface-200/30 mt-0.5">Rango en el 80% de simulaciones</div>
        </div>

        <!-- Margin calls -->
        <div class="text-center">
          <div class="text-xs text-surface-200/30 uppercase tracking-wider mb-2">Margin calls</div>
          <div class="text-2xl font-bold text-accent-green">Cero</div>
          <div class="text-[10px] text-surface-200/30 mt-0.5">Operando a 3.5‑4.4x leverage</div>
        </div>

        <!-- Recovery -->
        <div class="text-center">
          <div class="text-xs text-surface-200/30 uppercase tracking-wider mb-2">Velocidad de recuperación</div>
          <div class="text-2xl font-bold text-white">10‑14x</div>
          <div class="text-[10px] text-surface-200/30 mt-0.5">Más rápida tras drawdowns</div>
        </div>
      </div>

      <p class="text-center text-[10px] text-surface-200/20 mt-8">
        Rentabilidades pasadas no garantizan resultados futuros. Los backtests cubren un período predominantemente alcista.
      </p>
    </div>
  </div>
</section>
