<section class="py-24 sm:py-32 relative">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-px bg-gradient-to-r from-transparent via-brand-600/30 to-transparent"></div>

  <div class="mx-auto max-w-4xl px-6 text-center">
    <div class="fade-in relative rounded-2xl border border-brand-700/20 bg-gradient-to-b from-brand-950/50 to-surface-900/30 p-12 sm:p-16 overflow-hidden">
      <!-- Background glow -->
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[400px] h-[200px] bg-brand-600/10 rounded-full blur-[80px]"></div>

      <div class="relative z-10">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
          Deja de adivinar tu apalancamiento.<br class="hidden sm:block" /> Empieza a calcularlo.
        </h2>
        <p class="text-lg text-surface-200/50 mb-8 max-w-xl mx-auto">
          Configura tu portfolio en minutos. Toma decisiones con números reales en lugar de intuición.
        </p>
        <a
          href="https://app.margn.es"
          class="group inline-flex items-center gap-2 rounded-xl bg-brand-600 px-8 py-3.5 text-base font-semibold text-white hover:bg-brand-500 transition-all hover:shadow-[0_0_30px_rgba(92,124,250,0.3)]"
        >
          Crea tu cuenta gratuita
          <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
