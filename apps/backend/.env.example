# =============================================================================
# Backend Environment Variables
# =============================================================================
# Copy to .env and fill in values.
# Local dev defaults to staging credentials for safety.

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# --- Supabase Auth ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- App ---
FRONTEND_URL=http://localhost:3002
PORT=3003
CRON_SECRET_TOKEN=<random-hex-token>
